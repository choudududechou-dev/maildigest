# ===== 邮箱账户列表（多个逗号分隔，如：qq,netease,sina）=====
EMAIL_ACCOUNTS=qq

# ===== QQ邮箱 =====
EMAIL_QQ_ADDRESS=你的QQ号@qq.com
EMAIL_QQ_AUTH_CODE=你的16位授权码
EMAIL_QQ_IMAP_SERVER=imap.qq.com
EMAIL_QQ_IMAP_PORT=993

# ===== 163邮箱（如需添加，去掉下面4行开头的 #，并在 EMAIL_ACCOUNTS 中加上 netease）=====
#EMAIL_NETEASE_ADDRESS=你的手机号@163.com
#EMAIL_NETEASE_AUTH_CODE=你的授权码
#EMAIL_NETEASE_IMAP_SERVER=imap.163.com
#EMAIL_NETEASE_IMAP_PORT=993

# ===== 新浪邮箱 =====
#EMAIL_SINA_ADDRESS=你的账号@sina.com
#EMAIL_SINA_AUTH_CODE=你的授权码
#EMAIL_SINA_IMAP_SERVER=imap.sina.com
#EMAIL_SINA_IMAP_PORT=993

# ===== DeepSeek API =====
DEEPSEEK_API_KEY=sk-你的API-Key
DEEPSEEK_MODEL=deepseek-chat

# ===== 飞书推送 =====
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

DEBUG=false
